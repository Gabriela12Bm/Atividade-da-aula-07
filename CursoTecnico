public class CursoTecnico extends Curso {

    private String eixoTecnologico;
    private int chEstagio;

    public CursoTecnico(int codigo, String nome, int chTotal, int duracao, String tipoDuracao, String modalidade, String status, String eixoTecnologico, int chEstagio) {
        super(codigo, nome, chTotal, duracao, tipoDuracao, modalidade, status);
        this.eixoTecnologico = eixoTecnologico;
        this.chEstagio = chEstagio;
    }

System.out.println("Estagio obrigatorio? 0 pra não, 1 pra sim");

    public void verificarEstagio() {
        if (chEstagio > 0) {
System.out.println("Estagio obrigatorio");
        } else {
System.out.println("Estagio não obrigatorio");
        }
    }
}
